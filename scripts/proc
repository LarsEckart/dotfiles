#!/usr/bin/env bash
# Scaffold Procfile development files and copy shoreman.sh.

set -euo pipefail

cp "$HOME/.dotfiles/templates/proc/Procfile.template" ./Procfile
cp "$HOME/.dotfiles/templates/proc/.env.template" ./.env
cp "$HOME/.dotfiles/templates/proc/Makefile.template" ./Makefile
cp "$HOME/.dotfiles/scripts/shoreman.sh" .

echo "Created Procfile, .env, Makefile, and copied shoreman.sh"
echo "Run 'make dev' to start services, 'make stop' to stop, 'make logs' to view logs"

