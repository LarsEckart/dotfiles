#!/bin/bash
# Convert text to speech using the ElevenLabs Python script.

# Global text-to-speech script using ElevenLabs
# Usage: speak "your message here"

if [ $# -eq 0 ]; then
    echo "Usage: speak \"your message here\""
    exit 1
fi

# Change to speech directory and run the TTS script
cd ~/.dotfiles/speech && uv run text_to_speech_eleven_labs.py "$1"

